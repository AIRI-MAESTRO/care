# .env.example — documentation of every CARE_* environment variable.
#
# CareConfig (care/config.py) is the source of truth; this file mirrors
# every nested-config field as a commented stub so the surface is
# discoverable. Copy to `.env` and uncomment what you need, or run
# `care init`. Precedence (low→high): CareConfig defaults <
# ~/.config/care/config.toml < ./care.toml < CARE_* env vars.
# Nested fields use the `__` separator: CARE_<SECTION>__<FIELD>=value

# ── [mage] MAGE — query → CARL chain generation (LLM client + research toggles)
#CARE_MAGE__MODE=deep
#CARE_MAGE__API_KEY=
#CARE_MAGE__BASE_URL=
#CARE_MAGE__MODEL=
#CARE_MAGE__ENABLE_MEMORY_RESEARCH=true
#CARE_MAGE__MEMORY_SEARCH_MODE=bm25
#CARE_MAGE__MEMORY_RELEVANCE_THRESHOLD=0.0
#CARE_MAGE__ENABLE_WEB_RESEARCH=false
#CARE_MAGE__WEB_SEARCH_PROVIDER=tavily
#CARE_MAGE__WEB_SEARCH_API_KEY=
#CARE_MAGE__ENABLE_CAPABILITY_LOOKUP=false
#CARE_MAGE__ENABLE_MEMORY_SKILL_LOOKUP=false
#CARE_MAGE__ENABLE_SKILL_DISCOVERY=false
#CARE_MAGE__ENABLE_TOPOLOGY_SELECTION=true
#CARE_MAGE__TOPOLOGY_MAX_CANDIDATES=3
#CARE_MAGE__SIMPLICITY_BIAS=0.2
#CARE_MAGE__SIMPLICITY_MAX_STEPS=7

# ── [memory] GigaEvo Memory — entity store / library connection
#CARE_MEMORY__BASE_URL=http://localhost:8000
#CARE_MEMORY__API_KEY=
#CARE_MEMORY__TIMEOUT=30.0

# ── [platform] GigaEvo Platform — evolution (GA over chains) + validation/mutation LLMs
#CARE_PLATFORM__BASE_URL=http://localhost:8000
#CARE_PLATFORM__MASTER_BASE_URL=http://localhost:8000
#CARE_PLATFORM__API_KEY=
#CARE_PLATFORM__TIMEOUT=30.0
#CARE_PLATFORM__VALIDATION_BASE_URL=https://openrouter.ai/api/v1
#CARE_PLATFORM__VALIDATION_MODEL=tngtech/deepseek-r1t-chimera:free
#CARE_PLATFORM__VALIDATION_API_KEY=
#CARE_PLATFORM__MUTATION_BASE_URL=https://openrouter.ai/api/v1
#CARE_PLATFORM__MUTATION_MODEL=tngtech/deepseek-r1t-chimera:free
#CARE_PLATFORM__MUTATION_API_KEY=
#CARE_PLATFORM__MUTATION_MAX_TOKENS=8192
#CARE_PLATFORM__VALIDATION_MAX_TOKENS=2048

# ── [sandbox] AgentSkill sandbox backend (local / docker / e2b / firejail)
#CARE_SANDBOX__KIND=docker
#CARE_SANDBOX__CPU_LIMIT=2.0
#CARE_SANDBOX__MEM_LIMIT=1g
#CARE_SANDBOX__NETWORK_POLICY=skill_declared
#CARE_SANDBOX__IMAGE=python:3.12-slim
#CARE_SANDBOX__PIDS_LIMIT=256

# ── [tools] Tool discovery / synthesis / web-search + code-exec knobs
#CARE_TOOLS__PATH=~/.config/care/tools
#CARE_TOOLS__TAG_FILTER=
#CARE_TOOLS__NAME_PREFIX=
#CARE_TOOLS__ENABLE_BUILTINS=true
#CARE_TOOLS__WEB_SEARCH_PROVIDER=tavily
#CARE_TOOLS__WEB_SEARCH_API_KEY=
#CARE_TOOLS__SEARCH_PROVIDER_KEYS=
#CARE_TOOLS__WEB_SEARCH_MAX_RESULTS=5
#CARE_TOOLS__FETCH_URL_MAX_CHARS=4000
#CARE_TOOLS__ENABLE_CODE_EXEC=true
#CARE_TOOLS__CODE_EXEC_TIMEOUT=60
#CARE_TOOLS__AUTO_SYNTHESIZE_TOOLS=true
#CARE_TOOLS__SYNTHESIZED_TOOLS_PATH=~/.config/care/synthesized_tools
#CARE_TOOLS__SAVE_SYNTHESIZED_TO_MEMORY=true
#CARE_TOOLS__RECALL_TOOLS_FROM_MEMORY=true
#CARE_TOOLS__ROUTE_LIVE_DATA_TO_TOOLS=true
#CARE_TOOLS__GROUND_SYNTHESIS_WITH_WEB_SEARCH=true
#CARE_TOOLS__SELF_TEST_SYNTHESIZED_TOOLS=true
#CARE_TOOLS__VERIFY_CACHED_TOOLS=true
#CARE_TOOLS__CACHED_TOOL_HEALTH_TTL_S=86400

# ── [context] CARE.md project/global context + long-term memory (LTM)
#CARE_CONTEXT__ENABLED=true
#CARE_CONTEXT__GLOBAL_PATH=~/.config/care/CARE.md
#CARE_CONTEXT__PROJECT_FILENAME=CARE.md
#CARE_CONTEXT__MAX_CHARS=8000
#CARE_CONTEXT__AUTO_LEARN_FACTS=false
#CARE_CONTEXT__LTM_ENABLED=true
#CARE_CONTEXT__LTM_DIR=~/.config/care/ltm
#CARE_CONTEXT__LTM_SESSION_ID=default
#CARE_CONTEXT__LTM_INJECT_MAX_CHARS=2000
#CARE_CONTEXT__LTM_AUTOSAVE=true

# ── [artifacts] Session artifact store location
#CARE_ARTIFACTS__DIR=

# ── [upload] Optional file-upload endpoint for @-file refs
#CARE_UPLOAD__URL=
#CARE_UPLOAD__API_KEY=
#CARE_UPLOAD__AUTH_HEADER=Authorization
#CARE_UPLOAD__TIMEOUT=30.0

# ── [chat] Chat surface defaults (mode, save trim, per-mode stage policies)
#CARE_CHAT__DEFAULT_MODE=interactive
#CARE_CHAT__MODE=
#CARE_CHAT__INTERACTIVE_SAVE_TRIM=false

# ── [telemetry] Opt-in Langfuse telemetry sink
#CARE_TELEMETRY__ENABLED=false
#CARE_TELEMETRY__BACKEND=null
#CARE_TELEMETRY__HOST=https://cloud.langfuse.com
#CARE_TELEMETRY__PUBLIC_KEY=
#CARE_TELEMETRY__SECRET_KEY=

# ── [defaults] Misc UI / language / DAG-render defaults
#CARE_DEFAULTS__LANGUAGE=en
#CARE_DEFAULTS__UI_LANGUAGE=ru
#CARE_DEFAULTS__DAG_ASCII=false
#CARE_DEFAULTS__DAG_BUS_LANES=false
#CARE_DEFAULTS__DAG_LAYOUT=tb
#CARE_DEFAULTS__MAX_HISTORY_ENTRIES=50
# Disable UI animations (chat-line fade-in, modal/toast reveals, smooth scroll,
# stage-trail transitions). Equivalent to TEXTUAL_ANIMATIONS=none. Handy over
# slow SSH links or for motion sensitivity.
#CARE_DEFAULTS__REDUCED_MOTION=false

